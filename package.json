{
  "name": "appclaw",
  "version": "1.3.4",
  "description": "Agentic AI layer for mobile automation via appium-mcp",
  "type": "module",
  "main": "dist/sdk/index.js",
  "types": "dist/sdk/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/sdk/index.js",
      "types": "./dist/sdk/index.d.ts"
    },
    "./cli": {
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "appclaw": "bin/appclaw.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "start": "npx tsx src/index.ts",
    "dev": "npx tsx --watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run tests/flow tests/sdk",
    "test:e2e": "vitest run tests/e2e/",
    "test:e2e:android": "MCP_DEBUG=1 vitest run tests/e2e/android.test.ts",
    "test:watch": "vitest tests/flow tests/sdk",
    "build:vsix": "cd vscode-extension && npm run build && npx vsce package",
    "deploy:landing": "npm run deploy --prefix landing"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "1.2.12",
    "@ai-sdk/google": "3.0.79",
    "@ai-sdk/openai": "1.3.24",
    "@modelcontextprotocol/sdk": "1.29.0",
    "ai": "6.0.191",
    "ai-sdk-ollama": "3.8.3",
    "appium-mcp": "1.79.0",
    "boxen": "8.0.1",
    "chalk": "5.6.2",
    "cli-spinners": "3.4.0",
    "cli-table3": "0.6.5",
    "df-vision": "1.1.77",
    "dotenv": "17.4.2",
    "fast-xml-parser": "5.8.0",
    "gradient-string": "3.0.0",
    "marked": "15.0.12",
    "marked-terminal": "7.3.0",
    "mjpeg-consumer": "^2.0.0",
    "sharp": "0.33.5",
    "yaml": "2.8.4",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "11.0.6",
    "@semantic-release/npm": "12.0.2",
    "@semantic-release/release-notes-generator": "14.1.1",
    "@types/bun": "1.3.14",
    "@types/gradient-string": "1.1.6",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "prettier": "3.8.3",
    "semantic-release": "24.2.9",
    "tsx": "4.22.3",
    "typescript": "5.9.3",
    "vitest": "4.1.7"
  },
  "overrides": {
    "diff": "9.0.0",
    "appium-android-driver": {
      "ws": "8.21.0"
    },
    "js-yaml": "4.1.1",
    "minimatch": "10.2.5",
    "mocha": "11.7.6",
    "nanoid": "5.1.11",
    "onnxruntime-web": "1.26.0",
    "protobufjs": "7.6.1",
    "serialize-javascript": "7.0.5",
    "uuid": "14.0.0",
    "ws": "8.21.0"
  }
}
